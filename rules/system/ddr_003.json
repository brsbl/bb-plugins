{
  "schema_version": 1,
  "id": "ddr_003",
  "revision": 1,
  "title": "Extend the existing product language",
  "kind": "principle",
  "strength": "default",
  "statement": "Start from the closest established product surface, component, behavior, and token set; extend it before introducing bespoke UI.",
  "rationale": "Product consistency is judged by perceived lineage and behavior, not merely by matching a few colors.",
  "guidance": {
    "prefer": [
      "Find the closest product-native sibling and reuse its structure, tokens, and behavior.",
      "Introduce a new primitive only when existing ones cannot express the job."
    ],
    "avoid": [
      "Custom components whose anatomy or behavior feels unrelated to the host product.",
      "Copying surface color while inventing a different interaction language."
    ]
  },
  "classification": {
    "primary": "system.design-system",
    "secondary": [
      "product.architecture",
      "visual.hierarchy"
    ],
    "pattern_categories": [
