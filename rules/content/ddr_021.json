{
  "schema_version": 1,
  "id": "ddr_021",
  "revision": 1,
  "title": "Write in user-capability language",
  "kind": "principle",
  "strength": "default",
  "statement": "Write for the user's task and product vocabulary rather than internal implementation; avoid overly technical or granular explanations.",
  "rationale": "Product language should help users act and understand value, not expose the structure of the implementation.",
  "guidance": {
    "prefer": [
      "Name the user job, capability, and observable outcome.",
      "Use product vocabulary consistently."
    ],
    "avoid": [
      "Implementation terms that do not change the user's action.",
      "Granular process detail in primary copy."
    ]
  },
  "classification": {
    "primary": "content.terminology",
    "secondary": [
      "product.value",
      "content.instructions"
    ],
    "pattern_categories": [
      "Content & data"
    ]
  },
