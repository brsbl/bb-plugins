{
  "schema_version": 1,
  "id": "ddr_009",
  "revision": 1,
  "title": "Let content grow within explicit bounds",
  "kind": "guideline",
  "strength": "default",
  "statement": "Let inputs and surfaces grow with useful content to an explicit maximum; do not alter unrelated minimum constraints.",
  "rationale": "Useful content should not be artificially cramped, while unbounded growth and collateral resizing destabilize the surrounding layout.",
  "guidance": {
    "prefer": [
      "Grow with useful content until a clear maximum.",
      "Preserve unrelated minimum sizes and narrow-viewport constraints."
    ],
    "avoid": [
      "Fixed cramped surfaces for variable content.",
      "Changing a neighboring minimum merely to fit one state."
    ]
  },
  "classification": {
    "primary": "visual.layout",
    "secondary": [
