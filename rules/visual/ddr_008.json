{
  "schema_version": 1,
  "id": "ddr_008",
  "revision": 1,
  "title": "Reveal controls without reflow",
  "kind": "guideline",
  "strength": "default",
  "statement": "Hover, drag, and edit affordances must not shift row or panel geometry; transient controls should overlay or use reserved space.",
  "rationale": "Reflow under the pointer makes dense interfaces feel unstable and causes users to lose their target.",
  "guidance": {
    "prefer": [
      "Overlay transient actions or reserve their space.",
      "Keep the anchor and neighboring content stable."
    ],
    "avoid": [
      "Adding hover or edit controls that push content or resize the row."
    ]
  },
  "classification": {
    "primary": "visual.layout",
    "secondary": [
      "interaction.efficiency"
    ],
    "pattern_categories": [
