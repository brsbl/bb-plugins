{
  "schema_version": 1,
  "id": "ddr_018",
  "revision": 1,
  "title": "Represent state once on the owning control",
  "kind": "guideline",
  "strength": "default",
  "statement": "Encode installed, running, paused, and similar state once as a distinct state of the owning control; do not repeat it across rows or add competing toggles.",
  "rationale": "Duplicated state labels and parallel controls create ambiguity about ownership and the next available action.",
  "guidance": {
    "prefer": [
      "Let the owning control communicate current state and next action.",
      "Keep one canonical status location."
    ],
    "avoid": [
      "Repeating the same state label throughout a row.",
      "Adding a second toggle that competes with the primary state control."
    ]
  },
  "classification": {
    "primary": "interaction.feedback",
    "secondary": [
      "information.hierarchy"
    ],
    "pattern_categories": [
