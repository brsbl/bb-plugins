  "id": "ddr_016",
  "revision": 1,
  "title": "Keep hover effects local",
  "kind": "guideline",
  "strength": "default",
  "statement": "Hover styling and action changes belong to the owning row or control rather than an unrelated whole card.",
  "rationale": "Local hover scope makes the interactive target and ownership legible without lighting up unrelated content.",
  "guidance": {
    "prefer": [
      "Apply hover feedback to the smallest owning interactive region."
    ],
    "avoid": [
      "Changing an entire card when only one row or action is interactive."
    ]
  },
