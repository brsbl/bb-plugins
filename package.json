{
  "name": "bb-plugin-thread-hover-cards",
  "version": "0.1.0",
  "description": "Concise status previews for BB sidebar threads.",
  "type": "module",
  "scripts": {
    "build": "ESBUILD_BINARY_PATH=node_modules/.bin/esbuild bb plugin build .",
    "check": "npm run typecheck && npm run build && npm test",
    "test": "tsx --tsconfig test/tsconfig.json test/server.test.ts && node test/app.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bb": ">=0.0",
    "bbPluginSdk": "^0.4.0"
  },
  "bb": {
    "name": "Thread Hover Cards",
    "description": "Preview thread status, the latest request, and repository or PR context from the sidebar.",
    "branding": {
      "icon": "MessageSquare"
    },
    "server": "./server.ts",
    "app": "./app.tsx",
    "skills": []
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "better-sqlite3": "^12.0.0",
    "esbuild": "^0.28.1",
    "hono": "^4.11.9",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0"
  }
}
