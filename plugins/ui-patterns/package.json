{
  "name": "bb-plugin-ui-patterns",
  "version": "0.1.0",
  "description": "A global visual and agent-queryable browser for common UI terms and interaction patterns.",
  "type": "module",
  "keywords": [
    "bb-plugin",
    "design-system",
    "ui-patterns"
  ],
  "license": "UNLICENSED",
  "engines": {
    "bb": ">=0.0.32",
    "bbPluginSdk": "^0.4.0"
  },
  "bb": {
    "name": "UI Patterns",
    "description": "A global visual and agent-queryable browser for common UI terms and interaction patterns.",
    "branding": {
      "icon": "GridView"
    },
    "server": "./server.ts",
    "app": "./app.tsx",
    "skills": [
      "skills"
    ]
  },
  "files": [
    "dist/",
    "server.ts",
    "atlas-cli-v5.ts",
    "providers/",
    "generated/provider-snapshot.v2.json",
    "generated/provider-index.v2.json",
    "generated/preview-css.ts",
    "app.tsx",
    "assistant-ui-previews.tsx",
    "shadcn-demo-previews.tsx",
    "static-gallery-preview.tsx",
    "gallery-shell.tsx",
    "gallery-state.ts",
    "live-component-previews.tsx",
    "preview-frame-context.tsx",
    "source-browser-data.ts",
    "source-browser-model.ts",
    "components/",
    "vendor/shadcn-ui/",
    "vendor/base-ui/",
    "hooks/",
    "lib/",
    "skills/",
    "docs/",
    "README.md"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run build && npm test && npm run test:built",
    "typecheck": "tsc --noEmit",
    "update:providers": "node scripts/update-provider-sources.mjs",
    "build:providers": "node scripts/build-provider-snapshot.mjs",
    "check:providers": "node scripts/build-provider-snapshot.mjs --check",
    "build:preview-css": "node scripts/build-preview-css.mjs",
    "build": "node scripts/build.mjs",
    "test": "node --test tests/contract.test.mjs tests/source-browser-contract.test.mjs tests/provider-kernel.test.mjs tests/cli.test.mjs && vitest run server.harness.test.ts",
    "test:built": "vitest run built-server.test.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.27",
    "@base-ui/react": "1.6.0",
    "@hugeicons/core-free-icons": "^4.1.3",
    "@hugeicons/react": "^1.1.6",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@shadcn/react": "^0.2.1",
    "@tabler/icons-react": "3.31.0",
    "@tanstack/react-table": "8.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "^8.5.2",
    "input-otp": "^1.4.2",
    "lucide-react": "0.474.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.7.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bb/plugin-sdk": "file:../../tooling/vendor/bb-plugin-sdk-0.4.0.tgz",
    "@radix-ui/react-dialog": "^1.1.19",
    "@tailwindcss/node": "4.3.0",
    "@tailwindcss/oxide": "4.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^12.0.0",
    "cron-parser": "^5.5.0",
    "esbuild": "^0.28.1",
    "hono": "^4.11.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.3",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "^5.7.0",
    "vaul": "^1.1.2",
    "vitest": "^4.1.8"
  }
}
