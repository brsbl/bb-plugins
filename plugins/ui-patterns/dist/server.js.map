        {
          "nativeId": "alert",
          "name": "Alert",
          "aliases": [],
          "summary": {
            "text": "An alert is an element that displays a brief, important message in a way that attracts the user's attention without interrupting the user's task. Dynamically rendered alerts are automatically announced by most screen readers, and in some operating systems, they may trigger an alert sound. It is important to note that, at this time, screen readers do not inform users of alerts that are present on the page before page load completes.",
            "url": "https://www.w3.org/WAI/ARIA/apg/patterns/alert/#about"
          },
          "kind": "pattern",
          "canonicalUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/alert/",
          "sections": [
            {
              "nativeId": "about",
              "title": "About This Pattern",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/alert/#about",
              "content": null
            },
            {
              "nativeId": "examples",
              "title": "Example",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/alert/#examples",
              "content": null
            },
            {
              "nativeId": "keyboard_interaction",
              "title": "Keyboard Interaction",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/alert/#keyboard_interaction",
              "content": "Not applicable."
            },
            {
              "nativeId": "roles_states_properties",
              "title": "WAI-ARIA Roles, States, and Properties",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/alert/#roles_states_properties",
              "content": "The widget has a role of alert ."
            }
          ],
          "links": [
