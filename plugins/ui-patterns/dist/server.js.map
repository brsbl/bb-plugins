        {
          "nativeId": "breadcrumb",
          "name": "Breadcrumb",
          "aliases": [],
          "summary": {
            "text": "A breadcrumb trail consists of a list of links to the parent pages of the current page in hierarchical order. It helps users find their place within a website or web application. Breadcrumbs are often placed horizontally before a page's main content.",
            "url": "https://www.w3.org/WAI/ARIA/apg/patterns/breadcrumb/#about"
          },
          "kind": "pattern",
          "canonicalUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/breadcrumb/",
          "sections": [
            {
              "nativeId": "about",
              "title": "About This Pattern",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/breadcrumb/#about",
              "content": null
            },
            {
              "nativeId": "examples",
              "title": "Example",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/breadcrumb/#examples",
              "content": null
            },
            {
              "nativeId": "keyboard_interaction",
              "title": "Keyboard Interaction",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/breadcrumb/#keyboard_interaction",
              "content": "Not applicable."
            },
            {
              "nativeId": "roles_states_properties",
              "title": "WAI-ARIA Roles, States, and Properties",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/breadcrumb/#roles_states_properties",
              "content": "• Breadcrumb trail is contained within a navigation landmark region.\n• The landmark region is labelled via aria-label or aria-labelledby .\n• The link to the current page has aria-current set to page .\nIf the element representing the current page is not a link, aria-current is optional."
            }
          ],
          "links": [
            {
              "kind": "docs",
              "label": null,
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/breadcrumb/"
            },
            {
