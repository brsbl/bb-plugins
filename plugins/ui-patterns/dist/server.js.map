        {
          "nativeId": "disclosure",
          "name": "Disclosure (Show/Hide)",
          "aliases": [],
          "summary": {
            "text": "A disclosure is a widget that enables content to be either collapsed (hidden) or expanded (visible). It has two elements: a disclosure button and a section of content whose visibility is controlled by the button. When the controlled content is hidden, the button is often styled as a typical push button with a right-pointing arrow or triangle to hint that activating the button will display additional content. When the content is visible, the arrow or triangle typically points down.",
            "url": "https://www.w3.org/WAI/ARIA/apg/patterns/disclosure/#about"
          },
          "kind": "pattern",
          "canonicalUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/disclosure/",
          "sections": [
            {
              "nativeId": "about",
              "title": "About This Pattern",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/disclosure/#about",
              "content": null
            },
            {
              "nativeId": "examples",
              "title": "Examples",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/disclosure/#examples",
              "content": null
            },
            {
              "nativeId": "keyboard_interaction",
              "title": "Keyboard Interaction",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/disclosure/#keyboard_interaction",
              "content": "When the disclosure control has focus:\n• Enter : activates the disclosure control and toggles the visibility of the disclosure content.\n• Space : activates the disclosure control and toggles the visibility of the disclosure content."
            },
            {
              "nativeId": "roles_states_properties",
              "title": "WAI-ARIA Roles, States, and Properties",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/disclosure/#roles_states_properties",
              "content": "• The element that shows and hides the content has role button .\n• When the content is visible, the element with role button has aria-expanded set to true .\nWhen the content area is hidden, it is set to false .\n• Optionally, the element with role button has a value specified for aria-controls that refers to the element that contains all the content that is shown or hidden."
            }
          ],
          "links": [
            {
              "kind": "docs",
              "label": null,
