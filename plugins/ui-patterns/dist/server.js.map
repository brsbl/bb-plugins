        {
          "nativeId": "menu-button",
          "name": "Menu Button",
          "aliases": [],
          "summary": {
            "text": "A menu button is a button that opens a menu as described in the Menu and Menubar Pattern . It is often styled as a typical push button with a downward pointing arrow or triangle to hint that activating the button will display a menu.",
            "url": "https://www.w3.org/WAI/ARIA/apg/patterns/menu-button/#about"
          },
          "kind": "pattern",
          "canonicalUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/menu-button/",
          "sections": [
            {
              "nativeId": "about",
              "title": "About This Pattern",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/menu-button/#about",
              "content": null
            },
            {
              "nativeId": "examples",
              "title": "Examples",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/menu-button/#examples",
              "content": null
            },
            {
              "nativeId": "keyboard_interaction",
              "title": "Keyboard Interaction",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/menu-button/#keyboard_interaction",
              "content": "• With focus on the button:\n• Enter : opens the menu and places focus on the first menu item.\n• Space : Opens the menu and places focus on the first menu item.\n• (Optional) Down Arrow : opens the menu and moves focus to the first menu item.\n• (Optional) Up Arrow : opens the menu and moves focus to the last menu item.\n• The keyboard behaviors needed after the menu is open are described in the Menu and Menubar Pattern ."
            },
            {
              "nativeId": "roles_states_properties",
              "title": "WAI-ARIA Roles, States, and Properties",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/menu-button/#roles_states_properties",
              "content": "• The element that opens the menu has role button .\n• The element with role button has aria-haspopup set to either menu or true .\n• When the menu is displayed, the element with role button has aria-expanded set to true .\nWhen the menu is hidden, aria-expanded is set to false .\n• The element that contains the menu items displayed by activating the button has role menu .\n• Optionally, the element with role button has a value specified for aria-controls that refers to the element with role menu .\n• Additional roles, states, and properties needed for the menu element are described in the Menu and Menubar Pattern ."
            }
          ],
          "links": [
