        {
          "nativeId": "tooltip",
          "name": "Tooltip",
          "aliases": [],
          "summary": {
            "text": "NOTE: This design pattern is work in progress; it does not yet have task force consensus. Progress and discussions are captured in issue 128.",
            "url": "https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/#about"
          },
          "kind": "pattern",
          "canonicalUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/",
          "sections": [
            {
              "nativeId": "about",
              "title": "About This Pattern",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/#about",
              "content": null
            },
            {
              "nativeId": "examples",
              "title": "Example",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/#examples",
              "content": null
            },
            {
              "nativeId": "keyboard_interaction",
              "title": "Keyboard Interaction",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/#keyboard_interaction",
              "content": "Escape : Dismisses the Tooltip.\nNote\n• Focus stays on the triggering element while the tooltip is displayed.\n• If the tooltip is invoked when the trigger element receives focus, then it is dismissed when it no longer has focus (onBlur).\n• If the tooltip is invoked when a pointing cursor moves over the trigger element, then it remains open as long as the cursor is over the trigger or the tooltip."
            },
            {
              "nativeId": "roles_states_properties",
              "title": "WAI-ARIA Roles, States, and Properties",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/#roles_states_properties",
              "content": "• The element that serves as the tooltip container has role tooltip .\n• The element that triggers the tooltip references the tooltip element with aria-describedby ."
            }
          ],
          "links": [
            {
              "kind": "docs",
              "label": null,
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/"
            },
            {
              "kind": "code",
              "label": null,
              "url": "https://github.com/w3c/aria-practices/blob/18c1a2fca626f7aeb33270e23ae9b18833e2164d/content/patterns/tooltip/tooltip-pattern.html"
            }
          ],
