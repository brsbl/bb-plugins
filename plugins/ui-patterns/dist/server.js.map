              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/spinbutton/examples/quantity-spinbutton.html"
            }
          ],
          "relationships": [],
          "provenance": {
            "providerId": "aria-apg",
            "repository": "https://github.com/w3c/aria-practices",
