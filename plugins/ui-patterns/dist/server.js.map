        {
          "nativeId": "checkbox",
          "name": "Checkbox",
          "aliases": [],
          "summary": {
            "text": "WAI-ARIA supports two types of checkbox widgets: dual-state checkboxes toggle between two choices -- checked and not checked -- and tri-state checkboxes, which allow an additional third state known as partially checked.",
            "url": "https://www.w3.org/WAI/ARIA/apg/patterns/checkbox/#about"
          },
          "kind": "pattern",
          "canonicalUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/checkbox/",
          "sections": [
            {
              "nativeId": "about",
              "title": "About This Pattern",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/checkbox/#about",
              "content": null
            },
            {
              "nativeId": "examples",
              "title": "Examples",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/checkbox/#examples",
              "content": null
            },
            {
              "nativeId": "keyboard_interaction",
              "title": "Keyboard Interaction",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/checkbox/#keyboard_interaction",
              "content": "When the checkbox has focus, pressing the Space key changes the state of the checkbox."
            },
            {
              "nativeId": "roles_states_properties",
              "title": "WAI-ARIA Roles, States, and Properties",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/checkbox/#roles_states_properties",
              "content": "• The checkbox has role checkbox .\n• The checkbox has an accessible label provided by one of the following:\n• Visible text content contained within the element with role checkbox .\n• A visible label referenced by the value of aria-labelledby set on the element with role checkbox .\n• aria-label set on the element with role checkbox .\n• When checked, the checkbox element has state aria-checked set to true .\n• When not checked, it has state aria-checked set to false .\n• When partially checked, it has state aria-checked set to mixed .\n• If a set of checkboxes is presented as a logical group with a visible label, the checkboxes are included in an element with role group that has the property aria-labelledby set to the ID of the element containing the label.\n• If the presentation includes additional descriptive static text relevant to a checkbox or checkbox group, the checkbox or checkbox group has the property aria-describedby set to the ID of the element containing the description."
            }
          ],
