              "label": null,
              "url": "https://github.com/w3c/aria-practices/blob/18c1a2fca626f7aeb33270e23ae9b18833e2164d/content/patterns/slider-multithumb/slider-multithumb-pattern.html"
            }
          ],
          "examples": [
            {
