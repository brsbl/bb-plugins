            {
              "kind": "related-to",
              "label": "Menu and Menubar",
              "targetTitle": "Menu and Menubar",
              "targetUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/menubar/"
            }
          ],
          "provenance": {
            "providerId": "aria-apg",
            "repository": "https://github.com/w3c/aria-practices",
            "revision": "18c1a2fca626f7aeb33270e23ae9b18833e2164d",
