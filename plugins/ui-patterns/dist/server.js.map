        {
          "nativeId": "link",
          "name": "Link",
          "aliases": [],
          "summary": {
            "text": "A link widget provides an interactive reference to a resource. The target resource can be either external or local, i.e., either outside or within the current page or application.",
            "url": "https://www.w3.org/WAI/ARIA/apg/patterns/link/#about"
          },
          "kind": "pattern",
          "canonicalUrl": "https://www.w3.org/WAI/ARIA/apg/patterns/link/",
          "sections": [
            {
              "nativeId": "about",
              "title": "About This Pattern",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/link/#about",
              "content": null
            },
            {
              "nativeId": "examples",
              "title": "Examples",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/link/#examples",
              "content": null
            },
            {
              "nativeId": "keyboard_interaction",
              "title": "Keyboard Interaction",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/link/#keyboard_interaction",
              "content": "• Enter : Executes the link and moves focus to the link target.\n• Shift + F10 (Optional): Opens a context menu for the link."
            },
            {
              "nativeId": "roles_states_properties",
              "title": "WAI-ARIA Roles, States, and Properties",
              "url": "https://www.w3.org/WAI/ARIA/apg/patterns/link/#roles_states_properties",
              "content": "The element containing the link text or graphic has role of link ."
            }
