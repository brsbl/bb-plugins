{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.bb/design-doctrine/taxonomy.schema.json",
  "title": "Design Doctrine Taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "id_aliases",
    "deprecations",
    "roots",
    "pattern_categories",
    "products",
    "activities",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "updated_at": {"type": "string", "format": "date"},
    "id_aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "canonical_id", "reason", "created_at"],
        "properties": {
          "alias": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$"},
          "canonical_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$"},
          "reason": {"type": "string", "minLength": 3},
          "created_at": {"type": "string", "format": "date"}
        }
      }
    },
    "deprecations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "successor_ids", "reason", "deprecated_at"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$"},
          "successor_ids": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$"},
            "uniqueItems": true
          },
          "reason": {"type": "string", "minLength": 3},
          "deprecated_at": {"type": "string", "format": "date"}
        }
      }
    },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "definition", "leaves"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "name": {"type": "string", "minLength": 1},
          "definition": {"type": "string", "minLength": 3},
          "leaves": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name"],
              "properties": {
                "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"},
                "name": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "pattern_categories": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "name": {"type": "string", "minLength": 1}
        }
      }
    },
    "activities": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
      "uniqueItems": true
    },
    "artifacts": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
      "uniqueItems": true
    }
  }
}
