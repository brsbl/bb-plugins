{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@bb/plugin-sdk": ["./types/bb-plugin-sdk.d.ts"],
      "@bb/plugin-sdk/app": ["./types/bb-plugin-sdk-app.d.ts"],
      "@/*": ["./*"]
    },
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "server.ts",
    "app.tsx",
    "gallery-shell.tsx",
    "gallery-state.ts",
    "data.ts",
    "search.ts",
    "pattern-previews.tsx",
    "plugin-styles.ts",
    "providers/**/*.ts",
    "standalone.tsx",
    "types",
    "components",
    "atlas-ds/**/*.ts",
    "atlas-ds/**/*.tsx",
    "lib",
    "hooks"
  ]
}
